---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { getAllPosts } from "../lib/strapi";

const allPosts = await getAllPosts();
const sortedPosts = allPosts.sort((a : any, b : any) => {
  const da = a.data.date ? a.data.date.getTime() : 0;
  const db = b.data.date ? b.data.date.getTime() : 0;
  return db - da;
});
const categories = [...new Set(allPosts.map((p : any) => p.data.category).filter(Boolean))];
---

<Layout title="Buscar Publicaciones" description="Busca y filtra artículos del Blog UNAG">
  <img src="/img/hojas/hoja-angulo-01.webp" class="fixed left-0 -translate-x-20 top-80 lg:top-50 w-35 lg:w-50 z-10" alt="" aria-hidden="true" />
  <img src="/img/hojas/hoja-angulo-02.webp" class="fixed right-0 translate-x-20 w-35 lg:w-50 z-10" alt="" aria-hidden="true" />

  <section class="p-10 dark:bg-black bg-[url('/img/hero-banner-blog.jpg')] dark:bg-none bg-bottom bg-no-repeat">
    <div class="search-page__header pt-25">
      <span class="text-xs font-bold text-uppercase letter-spacing dark:text-white text-unag-gray">Explorar Archivo</span>
      <h1 class="text-2xl lg:text-5xl text-unag-gray dark:text-white font-extrabold mb-5">Descubre <span class="text-highlight">conocimiento</span>.</h1>

      <div class="mx-auto flex flex-col items-center gap-8">
        <div class="search-input-wrap">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input
            type="text"
            id="search-input"
            placeholder="Buscar temas, investigaciones, autores..."
            autocomplete="off"
          />
        </div>

        <div class="category-filters" id="category-filters">
          <button class="filter-chip active" data-category="all">Todos</button>
          {categories.map((cat : any) => (
            <button class="filter-chip" data-category={cat}>{cat}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="results-info">
      <span id="results-count">{sortedPosts.length}</span> resultados encontrados
    </div>

    <div class="search-results" id="posts-grid">
      {sortedPosts.map((post : any) => (
        <a
          href={`/posts/${post.data.slug}`}
          class="result-card"
          data-title={post.data.title?.toLowerCase()}
          data-description={post.data.description?.toLowerCase()}
          data-category={post.data.category}
        >
          <div class="result-card__img">
            <img src={post.data.image} alt={post.data.title} loading="lazy" />
          </div>
          <div class="result-card__body">
            <span class="category-tag">{post.data.category}</span>
            <h3 class="text-md font-bold text-unag-dark-green dark:text-white">{post.data.title}</h3>
            <p class="excerpt">{post.data.description}</p>
            <time class="date">{post.data.date ? post.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) : ''}</time>
          </div>
        </a>
      ))}
    </div>

    <div id="paginator" class="paginator hidden">
      <button class="pag-btn pag-btn--nav" id="pag-prev" aria-label="Página anterior">←</button>
      <div class="pag-pages" id="pag-pages"></div>
      <button class="pag-btn pag-btn--nav" id="pag-next" aria-label="Página siguiente">→</button>
    </div>

    <div id="empty-state" class="empty-state hidden">
      <div class="empty-state__icon">∅</div>
      <p class="empty-state__text">No encontramos nada que coincida con tu búsqueda.</p>
      <button class="empty-state__reset" id="reset-filters">Limpiar filtros</button>
    </div>
  </section>
</Layout>

<style>
  .search-page__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  :global(.dark) .search-page__title { color: var(--color-ink); }
  .text-highlight { color: var(--color-unag-green); }

  .search-controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
  }

  .search-input-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-ink);
    opacity: 0.4;
  }

  #search-input {
    width: 100%;
    padding: 1rem 1rem 1rem 3.5rem;
    height: 3.1rem;
    border-radius: 99px;
    border: 2px solid var(--color-rule);
    background: var(--color-paper-2);
    font-size: 13px;
    color: var(--color-ink);
    transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
  }

  #search-input:focus {
    outline: none;
    border-color: var(--color-unag-green);
    box-shadow: 0 0 0 4px var(--color-accent-soft);
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
  }

  .filter-chip {
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    background: var(--color-paper-2);
    border: 1px solid var(--color-rule);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    transition: all var(--dur-fast);
  }

  .filter-chip:hover { background: var(--color-rule); }

  .filter-chip.active {
    background: var(--color-unag-dark-green);
    color: #fff;
    border-color: var(--color-unag-dark-green);
  }
  :global(.dark) .filter-chip.active {
    background: var(--color-unag-green);
    border-color: var(--color-unag-green);
  }

  .results-info {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-ink);
    opacity: 0.5;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  /* Grid: 5 cols desktop, 3 tablet, 1 mobile */
  .search-results {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(5, 1fr);
  }

  .result-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--color-paper);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast);
  }

  .result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0,0,0,0.1);
  }

  .result-card__img {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .result-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-medium);
  }

  .result-card:hover .result-card__img img { transform: scale(1.05); }

  .result-card__body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xxs);
  }

  .category-tag {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-unag-green);
  }

  :global(.dark) .title { color: var(--color-ink); }

  .excerpt {
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-ink);
    opacity: 0.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .date {
    font-size: var(--text-xs);
    color: var(--color-ink);
    opacity: 0.4;
    margin-top: var(--space-xs);
  }

  /* Paginator */
  .paginator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-rule);
  }

  .pag-pages {
    display: flex;
    gap: 0.25rem;
  }

  .pag-btn {
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0 0.5rem;
    border-radius: 8px;
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    color: var(--color-ink);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--dur-fast), border-color var(--dur-fast), color var(--dur-fast);
  }

  .pag-btn:hover:not(:disabled):not(.pag-btn--active) {
    background: var(--color-rule);
    border-color: var(--color-unag-green);
  }

  .pag-btn:focus-visible {
    outline: 2px solid var(--color-unag-green);
    outline-offset: 2px;
  }

  .pag-btn--active {
    background: var(--color-unag-dark-green);
    border-color: var(--color-unag-dark-green);
    color: #fff;
  }

  :global(.dark) .pag-btn--active {
    background: var(--color-unag-green);
    border-color: var(--color-unag-green);
  }

  .pag-btn--nav { font-size: 1rem; }

  .pag-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .pag-ellipsis {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    font-size: 0.8125rem;
    color: var(--color-ink);
    opacity: 0.4;
    pointer-events: none;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .empty-state__icon {
    font-size: 4rem;
    color: var(--color-rule);
    margin-bottom: var(--space-md);
  }

  .empty-state__text {
    font-size: var(--text-base);
    color: var(--color-ink);
    opacity: 0.6;
    margin-bottom: var(--space-lg);
  }

  .empty-state__reset {
    padding: 0.75rem 1.5rem;
    background: var(--color-unag-green);
    color: #fff;
    border: none;
    border-radius: 99px;
    font-weight: 700;
    cursor: pointer;
  }

  .hidden { display: none !important; }

  @media (max-width: 1280px) {
    .search-results { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .search-page { padding-top: var(--space-3xl); }
    .search-results { grid-template-columns: 1fr; }
    .pag-btn { min-width: 2rem; height: 2rem; font-size: 0.75rem; }
  }
</style>

<script>
  const POSTS_PER_PAGE = 10;
  let currentPage = 1;

  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const categoryChips = document.querySelectorAll('.filter-chip');
  const postsGrid = document.getElementById('posts-grid');
  const resultsCount = document.getElementById('results-count');
  const emptyState = document.getElementById('empty-state');
  const resetBtn = document.getElementById('reset-filters');
  const paginator = document.getElementById('paginator');
  const pagPages = document.getElementById('pag-pages');
  const pagPrev = document.getElementById('pag-prev') as HTMLButtonElement | null;
  const pagNext = document.getElementById('pag-next') as HTMLButtonElement | null;
  const allCards = Array.from(postsGrid?.querySelectorAll('.result-card') ?? []) as HTMLElement[];

  let activeCategory = 'all';

  function getFilteredCards(): HTMLElement[] {
    const query = searchInput?.value.toLowerCase().trim() ?? '';
    return allCards.filter(card => {
      const title = card.getAttribute('data-title') ?? '';
      const desc = card.getAttribute('data-description') ?? '';
      const cat = card.getAttribute('data-category') ?? '';
      const matchesSearch = !query || title.includes(query) || desc.includes(query);
      const matchesCategory = activeCategory === 'all' || cat === activeCategory;
      return matchesSearch && matchesCategory;
    });
  }

  function getPageRange(current: number, total: number): (number | '…')[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const delta = 1;
    const mid: (number | '…')[] = [];
    for (let i = Math.max(2, current - delta); i <= Math.min(total - 1, current + delta); i++) {
      mid.push(i);
    }
    if ((mid[0] as number) > 2) mid.unshift('…');
    if ((mid[mid.length - 1] as number) < total - 1) mid.push('…');
    return [1, ...mid, total];
  }

  function renderPaginator(totalCount: number): void {
    if (!paginator || !pagPages || !pagPrev || !pagNext) return;
    const totalPages = Math.ceil(totalCount / POSTS_PER_PAGE);

    if (totalPages <= 1) {
      paginator.classList.add('hidden');
      return;
    }

    paginator.classList.remove('hidden');
    pagPrev.disabled = currentPage === 1;
    pagNext.disabled = currentPage === totalPages;

    const range = getPageRange(currentPage, totalPages);
    pagPages.innerHTML = range.map(p =>
      p === '…'
        ? `<span class="pag-ellipsis">…</span>`
        : `<button class="pag-btn${p === currentPage ? ' pag-btn--active' : ''}" data-page="${p}" aria-label="Página ${p}"${p === currentPage ? ' aria-current="page"' : ''}>${p}</button>`
    ).join('');
  }

  function renderPage(filteredCards: HTMLElement[]): void {
    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    allCards.forEach(c => c.classList.add('hidden'));
    filteredCards.slice(start, end).forEach(c => c.classList.remove('hidden'));

    if (resultsCount) resultsCount.textContent = filteredCards.length.toString();

    const isEmpty = filteredCards.length === 0;
    emptyState?.classList.toggle('hidden', !isEmpty);
    postsGrid?.classList.toggle('hidden', isEmpty);
  }

  function filterPosts(): void {
    const filtered = getFilteredCards();
    renderPage(filtered);
    renderPaginator(filtered.length);
  }

  function scrollToGrid(): void {
    postsGrid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Category chips
  categoryChips.forEach(chip => {
    chip.addEventListener('click', () => {
      categoryChips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeCategory = chip.getAttribute('data-category') ?? 'all';
      currentPage = 1;
      filterPosts();
    });
  });

  // Search input
  searchInput?.addEventListener('input', () => {
    currentPage = 1;
    filterPosts();
  });

  // Reset
  resetBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    categoryChips.forEach(c => c.classList.remove('active'));
    document.querySelector('[data-category="all"]')?.classList.add('active');
    activeCategory = 'all';
    currentPage = 1;
    filterPosts();
  });

  // Prev / Next
  pagPrev?.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; filterPosts(); scrollToGrid(); }
  });

  pagNext?.addEventListener('click', () => {
    const total = Math.ceil(getFilteredCards().length / POSTS_PER_PAGE);
    if (currentPage < total) { currentPage++; filterPosts(); scrollToGrid(); }
  });

  // Page number (delegado)
  pagPages?.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('[data-page]');
    if (!btn) return;
    const page = parseInt(btn.getAttribute('data-page') ?? '1');
    if (page !== currentPage) { currentPage = page; filterPosts(); scrollToGrid(); }
  });

  // URL param inicial
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('categoria');
  if (catParam) {
    const target = document.querySelector(`[data-category="${catParam}"]`);
    if (target) (target as HTMLElement).click();
    else filterPosts();
  } else {
    filterPosts();
  }
</script>
