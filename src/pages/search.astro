---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categories = [...new Set(allPosts.map((p) => p.data.category))];
---

<Layout title="Buscar Publicaciones" description="Busca y filtra artículos del Blog UNAG">
  <img src="/img/hojas/hoja-angulo-01.webp" class="fixed left-0 -translate-x-20 top-80 lg:top-50 w-35 lg:w-50 z-10" alt="" aria-hidden="true" />
  <img src="/img/hojas/hoja-angulo-02.webp" class="fixed right-0 translate-x-20 w-35 lg:w-50 z-10" alt="" aria-hidden="true" />

  <section class="p-10 dark:bg-black">
    <div class="search-page__header pt-25">
      <span class="text-xs font-bold text-uppercase letter-spacing dark:text-white text-unag-gray">Explorar Archivo</span>
      <h1 class="text-2xl lg:text-5xl text-unag-gray dark:text-white font-extrabold mb-5 ">Descubre <span class="text-highlight">conocimiento</span>.</h1>
      
      <div class="mx-auto flex flex-col items-center gap-8">
        <div class="search-input-wrap">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Buscar temas, investigaciones, autores..." 
            autocomplete="off"
          />
        </div>
        
        <div class="category-filters" id="category-filters">
          <button class="filter-chip active" data-category="all">Todos</button>
          {categories.map(cat => (
            <button class="filter-chip" data-category={cat}>{cat}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="results-info">
      <span id="results-count">{sortedPosts.length}</span> resultados encontrados
    </div>

    <div class="search-results" id="posts-grid">
      {sortedPosts.map((post) => (
        <a 
          href={`/blog/${post.id}`} 
          class="result-card"
          data-title={post.data.title.toLowerCase()}
          data-description={post.data.description.toLowerCase()}
          data-category={post.data.category}
        >
          <div class="result-card__img">
            <img src={post.data.image} alt={post.data.title} loading="lazy" />
          </div>
          <div class="result-card__body">
            <span class="category-tag">{post.data.category}</span>
            <h3 class="text-md font-bold text-unag-dark-green dark:text-white">{post.data.title}</h3>
            <p class="excerpt">{post.data.description}</p>
            <time class="date">{post.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          </div>
        </a>
      ))}
    </div>

    <div id="empty-state" class="empty-state hidden">
      <div class="empty-state__icon">∅</div>
      <p class="empty-state__text">No encontramos nada que coincida con tu búsqueda.</p>
      <button class="empty-state__reset" id="reset-filters">Limpiar filtros</button>
    </div>
  </section>
</Layout>

<style>
  

  .search-page__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

 
  :global(.dark) .search-page__title { color: var(--color-ink); }
  .text-highlight { color: var(--color-unag-green); }

  /* Search Controls */
  .search-controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
  }

  .search-input-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-ink);
    opacity: 0.4;
  }

  #search-input {
    width: 100%;
    padding: 1rem 1rem 1rem 3.5rem;
    height: 3.1rem;
    border-radius: 99px;
    border: 2px solid var(--color-rule);
    background: var(--color-paper-2);
    font-size: 13px;
    color: var(--color-ink);
    transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
  }

  #search-input:focus {
    outline: none;
    border-color: var(--color-unag-green);
    box-shadow: 0 0 0 4px var(--color-accent-soft);
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
  }

  .filter-chip {
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    background: var(--color-paper-2);
    border: 1px solid var(--color-rule);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    transition: all var(--dur-fast);
  }

  .filter-chip:hover {
    background: var(--color-rule);
  }

  .filter-chip.active {
    background: var(--color-unag-dark-green);
    color: #fff;
    border-color: var(--color-unag-dark-green);
  }
  :global(.dark) .filter-chip.active {
    background: var(--color-unag-green);
    border-color: var(--color-unag-green);
  }

  /* Results Info */
  .results-info {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-ink);
    opacity: 0.5;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  /* Results Grid */
  .search-results {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  .result-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--color-paper);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    transition: transform var(--dur-fast) var(--ease-out), shadow var(--dur-fast);
  }

  .result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0,0,0,0.1);
  }

  .result-card__img {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .result-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-medium);
  }

  .result-card:hover .result-card__img img {
    transform: scale(1.05);
  }

  .result-card__body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xxs);
  }

  .category-tag {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-unag-green);
  }

 
  :global(.dark) .title { color: var(--color-ink); }

  .excerpt {
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-ink);
    opacity: 0.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .date {
    font-size: var(--text-xs);
    color: var(--color-ink);
    opacity: 0.4;
    margin-top: var(--space-xs);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
  }

  .empty-state__icon {
    font-size: 4rem;
    color: var(--color-rule);
    margin-bottom: var(--space-md);
  }

  .empty-state__text {
    font-size: var(--text-base);
    color: var(--color-ink);
    opacity: 0.6;
    margin-bottom: var(--space-lg);
  }

  .empty-state__reset {
    padding: 0.75rem 1.5rem;
    background: var(--color-unag-green);
    color: #fff;
    border: none;
    border-radius: 99px;
    font-weight: 700;
    cursor: pointer;
  }

  .hidden { display: none; }

  @media (max-width: 768px) {
    .search-page { padding-top: var(--space-4xl); }
    .search-results { grid-template-columns: 1fr; }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input');
  const categoryChips = document.querySelectorAll('.filter-chip');
  const postsGrid = document.getElementById('posts-grid');
  const resultsCount = document.getElementById('results-count');
  const emptyState = document.getElementById('empty-state');
  const resetBtn = document.getElementById('reset-filters');
  const cards = postsGrid?.querySelectorAll('.result-card');

  let activeCategory = 'all';

  function filterPosts() {
    const query = searchInput?.value.toLowerCase().trim() || "";
    let visibleCount = 0;

    cards?.forEach((card) => {
      const title = card.getAttribute('data-title') || "";
      const desc = card.getAttribute('data-description') || "";
      const cat = card.getAttribute('data-category') || "";
      
      const matchesSearch = !query || title.includes(query) || desc.includes(query);
      const matchesCategory = activeCategory === 'all' || cat === activeCategory;
      
      const visible = matchesSearch && matchesCategory;
      card.classList.toggle('hidden', !visible);
      if (visible) visibleCount++;
    });

    if (resultsCount) resultsCount.textContent = visibleCount.toString();
    if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
    if (postsGrid) postsGrid.classList.toggle('hidden', visibleCount === 0);
  }

  // Handle category chip clicks
  categoryChips.forEach(chip => {
    chip.addEventListener('click', () => {
      categoryChips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeCategory = chip.getAttribute('data-category') || 'all';
      filterPosts();
    });
  });

  searchInput?.addEventListener('input', filterPosts);

  resetBtn?.addEventListener('click', () => {
    searchInput.value = '';
    categoryChips.forEach(c => c.classList.remove('active'));
    document.querySelector('[data-category="all"]')?.classList.add('active');
    activeCategory = 'all';
    filterPosts();
  });

  // Handle initial category from URL
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('categoria');
  if (catParam) {
    const targetChip = document.querySelector(`[data-category="${catParam}"]`);
    if (targetChip) {
      targetChip.click();
    }
  }
</script>
