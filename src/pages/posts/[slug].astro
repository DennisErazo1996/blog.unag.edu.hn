---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getAllPosts, getPostBySlug } from "../../lib/strapi";

type StrapiPost = {
  id: number | string;
  data: {
    title: string | null;
    description: string | null;
    content: string | Promise<string>;
    date: Date | null;
    category: string | null;
    author: string | null;
    image: string | string[] | null;
    slug: string | null;
  };
};

function resolveImage(image: string | string[] | null): string {
  if (!image) return '';
  return Array.isArray(image) ? (image[0] ?? '') : image;
}

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/404');

const post = await getPostBySlug(slug);
if (!post) return Astro.redirect('/404');

const allPosts: StrapiPost[] = (await getAllPosts()).filter(
  (p : any) => typeof p.data.slug === 'string' && p.data.slug
).sort((a : any, b : any) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const currentIndex = allPosts.findIndex((p) => p.data.slug === slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const relatedPosts: StrapiPost[] = allPosts
  .filter((p) => p.data.category === post.data.category && p.data.slug !== post.data.slug)
  .slice(0, 3);

function enhanceContent(html: string): string {
  if (!html) return html;
  // Add IDs to h2/h3 for TOC anchors
  let result = html.replace(/<(h[23])([^>]*)>([\s\S]*?)<\/\1>/g, (_, tag, attrs, inner) => {
    const text = inner.replace(/<[^>]*>/g, '').trim();
    const id = text.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').slice(0, 60);
    return `<${tag}${attrs} id="${id}">${inner}</${tag}>`;
  });
  // Gallery grouping
  const withItems = result.replace(
    /<p>\s*(<img[^>]*src="([^"]+)"[^>]*>)\s*<\/p>/g,
    '<div class="post-gallery__item"><a href="$2" class="post-gallery__link" data-lightbox>$1</a></div>'
  );
  return withItems.replace(/(?:<div class="post-gallery__item">[\s\S]*?<\/div>\s*)+/g, (match) => {
    return `<div class="post-gallery">${match}</div>`;
  });
}

const rawContent = await Promise.resolve(post.data.content);
const postContent = enhanceContent(rawContent);

// Gallery images
const rawGallery = (post.data as { gallery?: unknown }).gallery;
const galleryImages: string[] = Array.isArray(rawGallery)
  ? rawGallery.map((g) => resolveImage(g as string | string[] | null)).filter((url): url is string => url.length > 0)
  : [];

// Reading time
const plainText = rawContent.replace(/<[^>]*>/g, '');
const wordCount = plainText.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Share URLs
const postUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(post.data.title ?? '');
const shareUrls = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  whatsapp: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
};

// JSON-LD
const heroImage = resolveImage(post.data.image);
const jsonLdArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title ?? '',
  "description": post.data.description ?? '',
  "image": heroImage,
  "datePublished": post.data.date?.toISOString() ?? '',
  "author": {
    "@type": "Person",
    "name": post.data.author ?? 'UNAG'
  },
  "publisher": {
    "@type": "Organization",
    "name": "Universidad Nacional de Agricultura",
    "logo": {
      "@type": "ImageObject",
      "url": "https://blog.unag.edu.hn/img/logo-unag-verde-oscuro.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  }
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://blog.unag.edu.hn" },
    ...(post.data.category ? [{ "@type": "ListItem", "position": 2, "name": post.data.category, "item": `https://blog.unag.edu.hn/search?categoria=${encodeURIComponent(post.data.category)}` }] : []),
    { "@type": "ListItem", "position": post.data.category ? 3 : 2, "name": post.data.title ?? '' }
  ]
};
---

<!-- Hallmark · genre: editorial · macrostructure: Long Document · theme: UNAG custom -->

<Layout
  title={post.data.title}
  description={post.data.description}
  image={heroImage || undefined}
  type="article"
  publishedTime={post.data.date?.toISOString()}
  author={post.data.author ?? undefined}
  category={post.data.category ?? undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} slot="head" />

  <div id="reading-progress" class="fixed top-0 left-0 z-50 h-0.5 w-0 bg-unag-green transition-[width] duration-75" aria-hidden="true"></div>

  <article class="dark:bg-black">
    <!-- Hero editorial -->
    <div class="relative h-[55vh] min-h-80 overflow-hidden sm:h-[62vh]">
      <img
        src={heroImage}
        alt={post.data.title ?? ''}
        class="size-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-linear-to-t from-unag-dark-green/95 via-unag-dark-green/55 to-unag-dark-green/10" />
      <div class="absolute bottom-0 left-0 right-0 px-4 pb-8 pt-16 sm:px-8 sm:pb-10 lg:px-12 lg:pb-14">
        <div class="mx-auto max-w-3xl">
          <!-- Breadcrumb visual -->
          <nav aria-label="Ruta de navegación" class="mb-3 flex items-center gap-1.5 text-xs text-white/50">
            <a href="/" class="hover:text-white transition">Inicio</a>
            <span aria-hidden="true">›</span>
            {post.data.category && (
              <>
                <a href={`/search?categoria=${encodeURIComponent(post.data.category)}`} class="hover:text-white transition">{post.data.category}</a>
                <span aria-hidden="true">›</span>
              </>
            )}
            <span class="text-white/70 truncate max-w-50">{post.data.title}</span>
          </nav>

          <h1 class="mt-2 font-display text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
            {post.data.title}
          </h1>
          <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-white/55">
            {post.data.date ? (
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })}
              </time>
            ) : (
              <time>Fecha no disponible</time>
            )}
            {post.data.author && (
              <>
                <span aria-hidden="true">·</span>
                <span>{post.data.author}</span>
              </>
            )}
            <span aria-hidden="true">·</span>
            <span>{readingTime} min de lectura</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Barra superior: back + share -->
    <div class="border-b border-unag-dark-green/10 dark:border-white/10">
      <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
        <a
          href="/search"
          class="inline-flex items-center gap-1 text-xs font-medium text-unag-gray/50 transition hover:text-unag-green dark:text-white/40 dark:hover:text-unag-light-green"
        >
          <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Blog
        </a>
        <div class="flex items-center gap-1.5">
          <span class="mr-1 text-xs text-unag-gray/40 dark:text-white/30">Compartir</span>
          <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer" aria-label="Compartir en Facebook" class="share-icon-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" aria-label="Compartir en X" class="share-icon-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
