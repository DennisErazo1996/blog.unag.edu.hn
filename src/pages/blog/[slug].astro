---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .slice(0, 3);
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} image={post.data.image}>
  <article>
    <div class="relative h-[40vh] min-h-[280px] overflow-hidden sm:h-[45vh]">
      <img src={post.data.image} alt={post.data.title} class="size-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-unag-dark-green/90 via-unag-dark-green/40 to-transparent" />
      <img src="/img/hojas/hoja-desenfocada.webp" alt="" aria-hidden="true" class="pointer-events-none absolute -bottom-10 -right-10 size-48 rotate-12 opacity-5" />
      <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-8 lg:p-12">
        <div class="mx-auto max-w-3xl">
          <span class="inline-block rounded-full bg-unag-green/20 px-3 py-0.5 text-xs font-medium text-white backdrop-blur-sm">
            {post.data.category}
          </span>
          <h1 class="mt-3 text-2xl font-bold text-white sm:text-3xl lg:text-4xl">
            {post.data.title}
          </h1>
          <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-white/60">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })}
            </time>
            {post.data.author && <><span>&middot;</span><span>{post.data.author}</span></>}
          </div>
        </div>
      </div>
    </div>

    <div class="relative mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="prose prose-sm max-w-none dark:prose-invert [&_h2]:mt-8 [&_h2]:text-sm [&_h2]:font-bold [&_h2]:uppercase [&_h2]:tracking-wider [&_h2]:text-unag-dark-green dark:[&_h2]:text-white [&_h3]:mt-6 [&_h3]:text-sm [&_h3]:font-semibold [&_h3]:text-unag-green [&_p]:text-sm [&_p]:leading-relaxed [&_p]:text-unag-gray/80 dark:[&_p]:text-white/70 [&_blockquote]:border-l-4 [&_blockquote]:border-unag-green [&_blockquote]:bg-unag-light-gray/50 [&_blockquote]:px-4 [&_blockquote]:py-3 [&_blockquote]:text-sm [&_blockquote]:italic [&_blockquote]:text-unag-gray/80 dark:[&_blockquote]:bg-unag-dark-green/60 dark:[&_blockquote]:text-white/70 [&_ul]:text-sm [&_ul]:leading-relaxed [&_ul]:text-unag-gray/80 dark:[&_ul]:text-white/70 [&_li]:text-sm [&_li]:leading-relaxed [&_ul>&_li::marker]:text-unag-green [&_hr]:my-10 [&_hr]:border-unag-dark-green/10 dark:[&_hr]:border-white/10">
        <Content />
      </div>

      <div class="relative mt-12 border-t border-unag-dark-green/10 pt-8 dark:border-white/10">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-unag-green transition hover:text-unag-dark-green dark:hover:text-unag-light-green"
        >
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al blog
        </a>
      </div>
    </div>
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="relative mx-auto max-w-7xl border-t border-unag-dark-green/10 px-4 py-10 dark:border-white/10 sm:px-6 lg:px-8">
        <div class="relative">
          <h2 class="mb-6 text-sm font-bold uppercase tracking-wider text-unag-dark-green dark:text-white">
            Artículos relacionados
          </h2>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {
              relatedPosts.map((rp) => (
                <a
                  href={`/blog/${rp.id}`}
                  class="group relative flex flex-col overflow-hidden rounded-xl border border-unag-dark-green/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:border-white/10 dark:bg-unag-dark-green/80"
                >
                  <div class="aspect-[16/9] overflow-hidden">
                    <img
                      src={rp.data.image}
                      alt={rp.data.title}
                      class="size-full object-cover transition duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="flex flex-1 flex-col p-4">
                    <h3 class="text-sm font-bold text-unag-dark-green group-hover:text-unag-green dark:text-white dark:group-hover:text-unag-light-green">
                      {rp.data.title}
                    </h3>
                    <p class="mt-1 text-xs leading-relaxed text-unag-gray/70 dark:text-white/60">
                      {rp.data.description}
                    </p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    )
  }
</Layout>
